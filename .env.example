# === URLs de la aplicación ===
# URL base estable de la instancia LAN (Server-only).
# En producción debe ser la IP o hostname LAN del servidor (ej. http://192.168.1.50:3000 o http://fastorder.local:3000), NUNCA localhost.
APP_BASE_URL=http://localhost:3000
