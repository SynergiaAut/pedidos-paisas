# Credencial base 01 — GRANESLOSPAISAS
FLEX_CRM_EMAIL_01=correo_usuario_bd1
FLEX_CRM_CLAVE_01=clave_usuario_bd1
# Credencial base 02 — PAISASFISCAL (pendiente: usuario por crear con Ricardo)
FLEX_CRM_EMAIL_02=correo_usuario_bd2
FLEX_CRM_CLAVE_02=clave_usuario_bd2
# Vendedor dedicado para captura de pedidos (ej: 1114835229)
PEDIDOS_ID_VENDEDOR=codigo_vendedor_pedidos

# === Sync de inventario ===
